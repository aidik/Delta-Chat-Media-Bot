# .env configuration for Delta Media Bot
# Notes:
# - Values are read as strings unless noted.
# - Defaults shown below are the script's internal defaults when a variable is unset.
# - Copy this file to '.env' and adjust values for your environment.

# =====================
# Sender whitelist (REQUIRED)
# =====================
# Comma-separated list of allowed Delta Chat addresses the bot will respond to.
RESPOND_TO=user1@example.com,user2@example.com

# =====================
# Output paths (inside the container)
# =====================
# Bind-mount these to host directories your media server (Plex / Jellyfin) reads.
#DOWNLOAD_DIR=/downloads
#AUDIO_DIR=/downloads-audio

# =====================
# Quality
# =====================
# Optional max video height (e.g. 1080, 2160). Empty = true best available.
#MAX_HEIGHT=

# Comma-separated subtitle language codes to embed as soft tracks. Empty = no subs.
# Auto-generated subs are never included.
#SUBTITLE_LANGS=en

# =====================
# Safety net
# =====================
# Per-job timeout in seconds (default 14400 = 4 hours).
#JOB_TIMEOUT=14400
